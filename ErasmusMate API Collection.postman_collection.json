    {
      "name": "2. Smart Document Service",
      "item": [
        {
          "name": "Upload Document (AI Analyze)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"file_name\": \"health_insurance_2026.pdf\",\n  \"uploaded_text\": \"This document certifies that the student has valid health insurance coverage. Valid until 2026-06-30.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/documents/upload",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "documents",
                "upload"
              ]
            },
            "description": "Upload a document for AI analysis.\n\nThe service will automatically:\n1. Detect document type (HEALTH_INSURANCE, PASSPORT, LEARNING_AGREEMENT, etc.) using SpaCy NLP.\n2. Extract the expiration date from the text.\n3. Save it to the database.\n4. Publish a 'DocumentUploaded' event to RabbitMQ -> Notification Service will send an email + Socket.io notification.\n\nRequires JWT token (Bearer Auth)."
          },
          "response": []
        },
        {
          "name": "Get My Documents",
          "request": {
