{
  "info": {
    "_postman_id": "b0a998db-e3dd-4790-8288-7347c72b8f40",
    "name": "ErasmusMate API Collection",
    "description": "ErasmusMate Microservices - Complete API Collection.\n\nUsage:\n1. Import this collection into Postman.\n2. Register a student first.\n3. Login and copy the JWT token.\n4. Paste the token in the collection-level Authorization (Bearer Token).\n5. All other requests will use this token automatically.\n\nBase URL: http://localhost:3000 (API Gateway)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "51083594",
    "_collection_link": "https://go.postman.co/collection/51083594-b0a998db-e3dd-4790-8288-7347c72b8f40?source=collection_link"
  },
  "item": [
    {
      "name": "1. Student Profile Service",
      "item": [
        {
          "name": "Register Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"student_id\": 22118080701,\n  \"first_name\": \"Ceren\",\n  \"last_name\": \"Akmese\",\n  \"email\": \"akmeseeceren@gmail.com\",\n  \"password\": \"ceren123\",\n  \"home_university\": \"Gazi University\",\n  \"host_university\": \"Technical University of Munich\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/students/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "students",
                "register"
              ]
            },
            "description": "Register a new student. No token required. Returns the created student object."
          },
          "response": []
        },
        {
          "name": "Login Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set('jwt_token', jsonData.token);",
                  "    pm.environment.set('jwt_token',jsonData.token);",
                  "    console.log('JWT token saved to collection variable!');",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ali_yilmaz@gmail.com\",\n  \"password\": \"ali123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/students/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "students",
                "login"
              ]
            },
            "description": "Login with email and password. No token required.\n\nIMPORTANT: The test script automatically saves the JWT token to the {{jwt_token}} collection variable. You don't need to copy-paste it manually."
          },
          "response": []
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/students/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "students",
                "health"
              ]
            },
            "description": "Check if student profile service is running."
          },
          "response": []
