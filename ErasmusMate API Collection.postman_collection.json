                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Important: Semester Schedule Change\",\n  \"content\": \"The start of the winter semester has been moved to October 15th. Please update your travel plans accordingly.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/university/announcements",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "university",
                "announcements"
              ]
            },
            "description": "Post a new university announcement.\n\nThis is the most powerful endpoint in the system:\n1. The service fetches ALL registered students from Student Profile Service via REST.\n2. For each student, it publishes a 'NewAnnouncementPosted' event to RabbitMQ.\n3. Notification Service picks up each event, fetches the student's email via gRPC, and sends an individual email + Socket.io notification.\n\nRequires JWT token."
          },
          "response": []
